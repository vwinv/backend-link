generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum TeamMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum OfferBillingType {
  MONTHLY
  YEARLY
  LIFETIME
}

enum OfferAudience {
  PERSONAL
  TEAM
}

enum ShareMethod {
  LINK
  QR_CODE
  AIRDROP
  WHATSAPP
  NFC
  EMAIL
}

enum WalletType {
  APPLE_WALLET
  GOOGLE_WALLET
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

enum SocialPlatform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  FACEBOOK
  GITHUB
  WEBSITE
  YOUTUBE
  TIKTOK
  WHATSAPP
  CUSTOM
}

enum CardKind {
  PERSONAL
  PROFESSIONAL
}

enum ContactSource {
  EXCHANGE
  AI_SCAN
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String?
  authProvider AuthProvider @default(LOCAL)
  providerId   String?
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  stripeCustomerId String?      @unique
  role         UserRole     @default(USER)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ownedTeams           Team[]       @relation("TeamOwner")
  teamMemberships      TeamMember[]
  teamInvitesSent      TeamInvite[] @relation("TeamInvitesSent")
  teamInvitesReceived  TeamInvite[] @relation("TeamInvitesReceived")
  businessCards   BusinessCard[]
  subscriptions   Subscription[]
  savedCards      SavedCard[]
  shareEvents     ShareEvent[]
  cardSaveEvents  CardSaveEvent[]
  aiScanEvents    AiScanEvent[]
  contacts        Contact[]

  @@unique([authProvider, providerId])
  @@map("users")
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  brandColor  String?
  ownerId     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User           @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  invites       TeamInvite[]
  businessCards BusinessCard[]
  subscriptions Subscription[]

  @@map("teams")
}

model TeamInvite {
  id            String           @id @default(cuid())
  teamId        String
  email         String
  firstName     String?
  lastName      String?
  jobTitle      String?
  avatarUrl     String?
  invitedById   String
  inviteeUserId String?
  role          TeamMemberRole   @default(MEMBER)
  status        TeamInviteStatus @default(PENDING)
  expiresAt     DateTime?
  respondedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("TeamInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  invitee   User? @relation("TeamInvitesReceived", fields: [inviteeUserId], references: [id], onDelete: SetNull)

  @@index([teamId, status])
  @@index([email, status])
  @@map("team_invites")
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// ─── Business Cards ──────────────────────────────────────────────────────────

model BusinessCard {
  id            String   @id @default(cuid())
  slug          String   @unique
  ownerId       String
  teamId        String?
  kind          CardKind @default(PERSONAL)
  firstName     String
  lastName      String
  jobTitle      String?
  company       String?
  bio           String?
  email         String?
  phone         String?
  website       String?
  avatarUrl     String?
  coverImageUrl String?
  logoUrl       String?
  theme         Json     @default("{}")
  isPublic      Boolean  @default(true)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  socialLinks  SocialLink[]
  portfolio    Portfolio?
  savedCards   SavedCard[]
  shareEvents  ShareEvent[]
  cardViews    CardView[]
  cardSaves    CardSaveEvent[]
  contacts     Contact[]

  @@unique([ownerId, kind])
  @@map("business_cards")
}

model SocialLink {
  id        String         @id @default(cuid())
  cardId    String
  platform  SocialPlatform
  label     String?
  url       String
  order     Int            @default(0)
  createdAt DateTime       @default(now())

  card BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

// ─── Portfolio ───────────────────────────────────────────────────────────────

model Portfolio {
  id          String   @id @default(cuid())
  cardId      String   @unique
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  card     BusinessCard      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  projects PortfolioProject[]

  @@map("portfolios")
}

model PortfolioProject {
  id           String   @id @default(cuid())
  portfolioId  String
  title        String
  description  String?
  imageUrl     String?
  projectUrl   String?
  tags         String[] @default([])
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_projects")
}

// ─── Subscriptions & Plans ───────────────────────────────────────────────────

model Plan {
  id              String        @id @default(cuid())
  name            String        @unique
  slug            String        @unique
  description     String?
  priceMonthly    Decimal       @db.Decimal(10, 2)
  priceYearly     Decimal       @db.Decimal(10, 2)
  maxCards        Int           @default(1)
  maxTeamMembers  Int           @default(0)
  hasPortfolio    Boolean       @default(false)
  hasCustomDomain Boolean       @default(false)
  hasAnalytics    Boolean       @default(false)
  features        Json          @default("[]")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String?
  teamId           String?
  planId           String
  offerId          String?
  offerPriceId     String?
  status           SubscriptionStatus @default(TRIAL)
  billingPeriod    BillingPeriod      @default(MONTHLY)
  currentPeriodEnd DateTime?
  cancelledAt      DateTime?
  stripeSubscriptionId   String? @unique
  stripeCheckoutSessionId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user       User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  plan       Plan               @relation(fields: [planId], references: [id])
  offer      PremiumOffer?      @relation(fields: [offerId], references: [id], onDelete: SetNull)
  offerPrice PremiumOfferPrice? @relation(fields: [offerPriceId], references: [id], onDelete: SetNull)

  @@map("subscriptions")
}

model PremiumOffer {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  subtitle       String?
  audience       OfferAudience @default(PERSONAL)
  canCustomize   Boolean       @default(false)
  maxTeamMembers Int           @default(0)
  hasPortfolio   Boolean       @default(false)
  maxAiScans     Int           @default(0)
  sortOrder      Int           @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  prices        PremiumOfferPrice[]
  subscriptions Subscription[]

  @@map("premium_offers")
}

model PremiumOfferPrice {
  id              String           @id @default(cuid())
  offerId         String
  billingType     OfferBillingType
  priceLabel      String?
  priceAmount     Decimal          @db.Decimal(10, 2)
  currency        String           @default("FCFA")
  discountPercent Int?
  badgeLabel      String?
  isPopular       Boolean          @default(false)
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  stripePriceId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  offer         PremiumOffer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([offerId, billingType])
  @@map("premium_offer_prices")
}

// ─── Sharing & Wallet ────────────────────────────────────────────────────────

model ShareEvent {
  id        String      @id @default(cuid())
  cardId    String
  userId    String?
  method    ShareMethod
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now())

  card BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("share_events")
}

model SavedCard {
  id         String     @id @default(cuid())
  userId     String
  cardId     String
  walletType WalletType
  passId     String?
  savedAt    DateTime   @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  card BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId, walletType])
  @@map("saved_cards")
}

model CardView {
  id        String   @id @default(cuid())
  cardId    String
  ipAddress String?
  userAgent String?
  referrer  String?
  viewedAt  DateTime @default(now())

  card BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_views")
}

model CardSaveEvent {
  id      String   @id @default(cuid())
  cardId  String
  userId  String?
  savedAt DateTime @default(now())

  card BusinessCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("card_save_events")
}

// ─── AI Scans ────────────────────────────────────────────────────────────────

model AiScanEvent {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact?

  @@index([userId, createdAt])
  @@map("ai_scan_events")
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  userId       String
  source       ContactSource
  firstName    String
  lastName     String
  email        String?
  phone        String?
  jobTitle     String?
  company      String?
  linkedCardId String?
  scanEventId  String?       @unique
  avatarColor  Int           @default(683007)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedCard BusinessCard? @relation(fields: [linkedCardId], references: [id], onDelete: SetNull)
  scanEvent  AiScanEvent?  @relation(fields: [scanEventId], references: [id], onDelete: SetNull)

  @@unique([userId, linkedCardId])
  @@index([userId, createdAt])
  @@map("contacts")
}
