# Application
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://link:link@localhost:5432/link_db?schema=public"

# JWT (tokens API après authentification OAuth 2.0 ou locale)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# OAuth 2.0 / OpenID Connect
# IDs clients Google (séparés par des virgules) : Web + iOS + Android
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com
# Bundle ID iOS (Sign in with Apple + Universal Links) — identique à Xcode
APPLE_CLIENT_ID=com.mega.dropone
# Team ID Apple Developer (10 caractères) — requis pour Universal Links
APPLE_TEAM_ID=3G878MZ2JV
# Package Android (build.gradle applicationId) + empreinte SHA-256 du keystore release
ANDROID_APP_PACKAGE=com.mega.dropone
# Plusieurs empreintes possibles (debug + release), séparées par des virgules
ANDROID_APP_SHA256_CERT=

# URL publique des cartes (QR code dans les passes Wallet)
APP_PUBLIC_URL=https://dropone.pro

# ─── E-mail (invitations équipe) ─────────────────────────────────────────────
# Mettre SMTP_ENABLED=false pour désactiver l'envoi (dev sans SMTP)
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=DropOne <noreply@dropone.pro>

# ─── Stripe (paiement abonnements) ───────────────────────────────────────────
# STRIPE_ENABLED=false → souscription instantanée sans paiement (tests)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://dropone.pro/premium/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://dropone.pro/premium/cancel

# IDs des prix Stripe (Dashboard Stripe → Produits → Prix)
STRIPE_PRICE_LINK_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_LINK_PREMIUM_YEARLY=price_...
STRIPE_PRICE_LINK_PREMIUM_LIFETIME=price_...
STRIPE_PRICE_LINK_PREMIUM_TEAM_MONTHLY=price_...
STRIPE_PRICE_LINK_PREMIUM_TEAM_YEARLY=price_...
STRIPE_PRICE_LINK_PREMIUM_TEAM_LIFETIME=price_...

# ─── Apple Wallet (PassKit) ──────────────────────────────────────────────────
# Team ID Apple Developer (10 caractères)
APPLE_TEAM_ID=
# Pass Type ID créé dans Certificates, Identifiers & Profiles
APPLE_PASS_TYPE_ID=pass.com.votredomaine.link
# Certificat WWDR Apple (télécharger depuis Apple)
APPLE_WWDR_CERT_PATH=./certs/AppleWWDRCAG4.pem
# Certificat Pass Type ID (.pem exporté depuis Keychain)
APPLE_PASS_SIGNER_CERT_PATH=./certs/pass_certificate.pem
# Clé privée du certificat Pass (.pem ou .key)
APPLE_PASS_SIGNER_KEY_PATH=./certs/pass_private_key.pem
# Passphrase si la clé est protégée (laisser vide sinon)
APPLE_PASS_SIGNER_KEY_PASSPHRASE=

# ─── Google Wallet ───────────────────────────────────────────────────────────
# Issuer ID depuis Google Pay & Wallet Console
GOOGLE_WALLET_ISSUER_ID=
# Suffixe de la classe générique (objet = {ISSUER_ID}.card_{cardId})
GOOGLE_WALLET_CLASS_SUFFIX=link_business_card
# Chemin vers le JSON du compte de service Google
GOOGLE_WALLET_SERVICE_ACCOUNT_PATH=./certs/google-wallet-service-account.json
# Origines autorisées pour le JWT (optionnel, séparées par des virgules)
GOOGLE_WALLET_ORIGINS=https://dropone.pro
